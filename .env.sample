SHARED_ALBUM_URL=https://photos.app.goo.gl/ABC123
DITHER_MODE=STUCKI
IMAGE_WIDTH=800
IMAGE_HEIGHT=480
LANDSCAPE_ONLY=true
CACHE_TTL_MINUTES=60

# Cropping Strategy: CENTER, TOP, RIGHT, BOTTOM, LEFT, ENTROPY, ATTENTION
CROP_STRATEGY=CENTER

# Scraper configuration for large albums or slower internet/hardware (default values shown)
SCRAPER_MAX_NO_NEW_PHOTOS=200
SCRAPER_MAX_SCROLL_ATTEMPTS=3000
SCRAPER_SCROLL_DELAY=200