{
  "name": "stillness",
  "version": "1.0.0",
  "description": "Node.js app to serve 1-bit images from Google Photos for e-paper displays",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node dist/src/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "test": "tsx --test test/**/*.test.ts",
    "test:watch": "tsx --test --watch test/**/*.test.ts",
    "postinstall": "patch-package"
  },
  "keywords": [],
  "author": "oscarb",
  "license": "ISC",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@opendisplay/epaper-dithering": "^2.1.3",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "flat-cache": "^6.1.20",
    "google-photos-album-image-url-fetch": "^3.2.0",
    "google-photos-scraper": "^1.0.0",
    "patch-package": "^8.0.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
